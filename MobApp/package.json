{
  "name": "eldercare-ai",
  "version": "1.0.0",
  "private": true,
  "description": "ElderCare AI Mobile Application — Full-Stack Monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:server": "npm run dev -w apps/server",
    "dev:mobile": "npm run dev -w apps/mobile",
    "build:server": "npm run build -w apps/server",
    "db:migrate": "npm run db:migrate -w apps/server",
    "db:push": "npm run db:push -w apps/server",
    "db:studio": "npm run db:studio -w apps/server",
    "db:generate": "npm run db:generate -w apps/server",
    "lint": "echo \"Add linter\"",
    "clean": "rimraf **/node_modules **/dist **/.expo"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "allowScripts": {
    "@prisma/client@6.19.3": true,
    "@prisma/engines@6.19.3": true,
    "esbuild@0.28.1": true,
    "prisma@6.19.3": true
  }
}
