# ==============================================
# ElderCare AI — Environment Variables
# ==============================================
# Copy this file to .env and fill in the values.

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/eldercare_db?schema=public"

# JWT Authentication
JWT_SECRET="your-super-secret-jwt-key-change-this"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV="development"

# Frontend (Expo)
EXPO_PUBLIC_API_URL="http://localhost:3001/api"
